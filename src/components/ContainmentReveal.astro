---
/** Product reveal scene: a rotating containment ring opens while the
 *  panel inside blooms into place. One-shot on scroll entry.
 *  Reduced motion / no JS: panel fully visible, ring static and dim. */
---
<div class="containment" data-reveal="bloom">
  <svg class="containment-ring" viewBox="0 0 800 800" fill="none" aria-hidden="true">
    <circle class="ring r1" cx="400" cy="400" r="380" stroke="rgba(15,76,130,0.7)" stroke-width="1.5" stroke-dasharray="40 24" />
    <circle class="ring r2" cx="400" cy="400" r="330" stroke="rgba(100,254,218,0.22)" stroke-width="1" stroke-dasharray="4 16" />
    <circle class="ring r3" cx="400" cy="400" r="285" stroke="rgba(165,210,245,0.18)" stroke-width="1" />
  </svg>
  <div class="containment-glow" aria-hidden="true"></div>
  <div class="containment-inner">
    <slot />
  </div>
</div>

<style>
  .containment {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(1rem, 4vw, 2.5rem);
  }
  .containment-ring {
    position: absolute;
    inset: 50% auto auto 50%;
    width: min(800px, 130%);
    height: auto;
    translate: -50% -50%;
    pointer-events: none;
    z-index: 0;
  }
  .containment-glow {
    position: absolute;
    inset: 50% auto auto 50%;
    width: 70%;
    aspect-ratio: 1;
    translate: -50% -50%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(100,254,218,0.09) 0%, rgba(15,76,130,0.18) 45%, transparent 70%);
    filter: blur(30px);
    pointer-events: none;
    z-index: 0;
  }
  .containment-inner {
    position: relative;
    z-index: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html.jsm) .ring {
      transform-origin: center;
      transition: opacity 1.4s ease 0.5s;
    }
    :global(html.jsm) .containment.in .r1 { animation: ring-open-a 14s linear infinite; opacity: 0.5; }
    :global(html.jsm) .containment.in .r2 { animation: ring-open-b 22s linear infinite reverse; opacity: 0.7; }
    :global(html.jsm) .containment.in .r3 { animation: ring-open-a 30s linear infinite; opacity: 0.6; }
    :global(html.jsm) .containment-glow {
      opacity: 0;
      transition: opacity 1.2s ease 0.25s;
    }
    :global(html.jsm) .containment.in .containment-glow { opacity: 1; }
    @keyframes ring-open-a { to { transform: rotate(360deg); } }
    @keyframes ring-open-b { to { transform: rotate(360deg); } }
  }
</style>
