---
/** Bottom CTA panel. Copy is passed in unchanged from each page.
 *  Actions go in the default slot (existing <a> buttons). */
interface Props {
  title: string;
  text?: string;
  kicker?: string;
}
const { title, text, kicker } = Astro.props;
---
<section class="section-sm scene">
  <div class="container">
    <div class="cta-panel card no-hover card-p-lg cta-scene" style="border-radius:var(--radius-lg);" data-reveal>
      <svg class="cta-rings ring-spin" viewBox="0 0 600 600" aria-hidden="true" fill="none">
        <circle cx="300" cy="300" r="260" stroke="rgba(100,254,218,0.06)" stroke-width="1.5" stroke-dasharray="6 14" />
        <circle cx="300" cy="300" r="190" stroke="rgba(165,210,245,0.07)" stroke-width="1" />
        <circle cx="300" cy="300" r="120" stroke="rgba(100,254,218,0.09)" stroke-width="1" stroke-dasharray="2 10" />
      </svg>
      <h2 class="display-sm" style="margin-bottom:0.75rem;">{title}</h2>
      {text && <p>{text}</p>}
      <div class="cta-actions">
        <slot />
      </div>
    </div>
  </div>
</section>

<style>
  .cta-scene { position: relative; }
  .cta-rings {
    position: absolute;
    inset: 50% auto auto 50%;
    width: min(600px, 120%);
    height: auto;
    translate: -50% -50%;
    pointer-events: none;
    z-index: 0;
  }
</style>
