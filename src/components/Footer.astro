---
const socials = [
  { href: 'https://www.tiktok.com/@cognielevate',        label: 'TikTok',    icon: 'tiktok'    },
  { href: 'https://www.instagram.com/cognifocus.app/',   label: 'Instagram', icon: 'instagram' },
  { href: 'https://www.facebook.com/share/1Am7kCzkjG/', label: 'Facebook',  icon: 'facebook'  },
  { href: 'https://x.com/cognielevate',                  label: 'X',         icon: 'x'         },
  { href: 'https://discord.gg/HbU3XYyFCz',              label: 'Discord',   icon: 'discord'   },
  { href: 'https://wa.me/923262878356',                  label: 'WhatsApp',  icon: 'whatsapp'  },
];

const navLinks = [
  { href: '/',          label: 'Home'         },
  { href: '/about',     label: 'About'        },
  { href: '/products',  label: 'Products'     },
  { href: '/blog',      label: 'Blog'         },
  { href: '/resources', label: 'Resources'    },
  { href: '/contact',   label: 'Contact'      },
  { href: '/privacy',   label: 'Privacy'      },
];
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <a href="/" aria-label="CogniElevate home">
            <img src="/assets/cognielevate.png" alt="CogniElevate" width="120" height="28" />
          </a>
          <p>Intelligent systems that give people their time back.</p>
          <div class="socials mt-lg">
            {socials.map(({ href, label, icon }) => (
              <a
                href={href}
                class="social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
              >
                <img
                  src={`https://cdn.jsdelivr.net/gh/simple-icons/simple-icons/icons/${icon}.svg`}
                  alt=""
                  aria-hidden="true"
                  width="16"
                  height="16"
                />
              </a>
            ))}
          </div>
        </div>

        <nav class="footer-links" aria-label="Footer navigation">
          {navLinks.map(({ href, label }) => (
            <a href={href} class="footer-link">{label}</a>
          ))}
        </nav>
      </div>

      <div class="footer-bottom">
        <span>© 2026 CogniElevate. All rights reserved.</span>
        <a
          href="https://cognifocus.app/"
          target="_blank"
          rel="noopener"
          style="color: var(--accent); text-decoration: none; font-weight: 500;"
        >
          Try CogniFocus →
        </a>
      </div>
    </div>
  </div>
</footer>
