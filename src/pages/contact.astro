---
import BaseLayout from '../layouts/BaseLayout.astro';
import Scene from '../components/Scene.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaPanel from '../components/CtaPanel.astro';
import {
  coreKeywords,
  organizationSchema,
  websiteSchema,
  webPageSchema,
  breadcrumbSchema,
} from '../data/seo.js';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    organizationSchema,
    websiteSchema,
    webPageSchema({
      id: 'https://cognielevate.co/contact/#webpage',
      url: 'https://cognielevate.co/contact/',
      name: 'Contact CogniElevate | Partnerships, Feedback and Product Interest',
      description: 'Contact CogniElevate for partnerships, product feedback, future solution ideas, or interest in CogniFocus and upcoming intelligent products.',
      breadcrumb: true,
    }),
    breadcrumbSchema({
      id: 'https://cognielevate.co/contact/#breadcrumb',
      items: [
        { name: 'Home', url: 'https://cognielevate.co/' },
        { name: 'Contact', url: 'https://cognielevate.co/contact/' },
      ],
    }),
  ]
};

const socialLinks = [
  { href: 'https://www.tiktok.com/@cognielevate',        icon: 'tiktok',    label: 'TikTok'    },
  { href: 'https://www.instagram.com/cognifocus.app/',   icon: 'instagram', label: 'Instagram' },
  { href: 'https://www.facebook.com/share/1Am7kCzkjG/', icon: 'facebook',  label: 'Facebook'  },
  { href: 'https://x.com/iqasim_explores',                  icon: 'x',         label: 'X'         },
  { href: 'https://discord.gg/HbU3XYyFCz',              icon: 'discord',   label: 'Discord'   },
  { href: 'https://wa.me/923262878356',                  icon: 'whatsapp',  label: 'WhatsApp'  },
];

const topics = [
  { label: 'Partnerships',                  icon: 'users'   },
  { label: 'Product feedback',              icon: 'star'    },
  { label: 'CogniFocus support or interest', icon: 'focus'  },
  { label: 'Future solution ideas',         icon: 'brain'   },
  { label: 'Media or listing requests',     icon: 'monitor' },
  { label: 'General enquiries',             icon: 'bell'    },
];
---

<BaseLayout
  title="Contact CogniElevate | Partnerships, Feedback and Product Interest"
  description="Contact CogniElevate for partnerships, product feedback, future solution ideas, or interest in CogniFocus and upcoming intelligent products."
  canonical="https://cognielevate.co/contact/"
  keywords={[...coreKeywords, 'contact CogniElevate', 'CogniElevate partnerships', 'product feedback', 'startup contact']}
  activePage="contact"
  schema={schema}
>

  <Scene class="hero bg-dots" aria-labelledby="contact-title">
    <Fragment slot="far">
      <div class="glow-top"></div>
      <div class="glow-field accent" style="width:40vw;height:40vh;top:5%;right:0;opacity:0.5;"></div>
    </Fragment>
    <Fragment slot="mid">
      <svg class="portal-ring" viewBox="0 0 400 400" fill="none" aria-hidden="true">
        <circle cx="200" cy="200" r="170" stroke="rgba(100,254,218,0.14)" stroke-width="1.5" stroke-dasharray="40 18" class="ring-spin" style="--spin-dur:50s;" />
        <circle cx="200" cy="200" r="130" stroke="rgba(165,210,245,0.16)" stroke-width="1" class="ring-spin reverse" style="--spin-dur:70s;" />
        <circle cx="200" cy="200" r="90" stroke="rgba(15,76,130,0.6)" stroke-width="1.5" stroke-dasharray="3 10" />
        <circle cx="200" cy="30" r="5" fill="#64FEDA" class="node-pulse" />
      </svg>
    </Fragment>
    <div class="container" style="position:relative;">
      <div style="max-width:760px;" class="fade-up hero-center">
        <h1 id="contact-title" class="hero-title">Contact CogniElevate</h1>
        <p class="lead" style="margin-top:1.25rem;">
          Reach out for partnerships, feedback, product interest, or future solution ideas. We read everything.
        </p>
      </div>
    </div>
  </Scene>

  <!-- EMAIL -->
  <Scene class="section" aria-labelledby="email-heading">
    <div class="container" style="max-width:700px;">
      <SectionHead kicker="Get in touch" title="Drop us a message" id="email-heading" />

      <div class="card card-p-lg no-hover depth-panel" data-reveal style="display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">
        <div class="contact-icon-wrap" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3.75 6.75h16.5a1.5 1.5 0 0 1 1.5 1.5v7.5a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-7.5a1.5 1.5 0 0 1 1.5-1.5Z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
            <path d="m4.5 8.25 6.53 5.22a1.55 1.55 0 0 0 1.94 0l6.53-5.22" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
          </svg>
        </div>
        <div>
          <a href="mailto:cognielevate@gmail.com" style="font-size:1.15rem;font-weight:600;color:var(--accent);text-decoration:none;">
            cognielevate@gmail.com
          </a>
          <p style="margin-top:0.5rem;font-size:0.92rem;">
            Reach out for partnerships, feedback, product interest, or future solution ideas.
          </p>
        </div>
      </div>
    </div>
  </Scene>

  <!-- TOPICS -->
  <Scene class="section" style="background:var(--surface);" aria-labelledby="topics-heading">
    <div class="container" style="max-width:700px;">
      <SectionHead kicker="What to contact us about" title="Ways we can collaborate" id="topics-heading" />
      <div class="grid-2" data-reveal-stagger>
        {topics.map(({ label, icon }) => (
          <div class="card card-p topic-card" style="font-size:0.92rem;font-weight:500;color:var(--text-2);">
            <span class="topic-icon" aria-hidden="true">
              <img src={`/assets/icons/${icon}.svg`} alt="" width="16" height="16" loading="lazy" />
            </span>
            {label}
          </div>
        ))}
      </div>
    </div>
  </Scene>

  <!-- SOCIAL -->
  <Scene class="section" aria-labelledby="social-heading">
    <div class="container" style="max-width:700px;">
      <SectionHead kicker="Social links" title="Connect with CogniElevate" id="social-heading" />
      <div class="socials" data-reveal-stagger>
        {socialLinks.map(({ href, icon, label }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={label}>
            <img src={`/assets/icons/${icon}.svg`} alt="" width="16" height="16" aria-hidden="true" />
          </a>
        ))}
      </div>
    </div>
  </Scene>

  <!-- CTA -->
  <CtaPanel title="Want to see what we have built first?">
    <a href="https://cognifocus.app/" target="_blank" rel="noopener" class="btn btn-primary btn-lg">Visit CogniFocus</a>
    <a href="/products/" class="btn btn-outline btn-lg">All products</a>
  </CtaPanel>

</BaseLayout>

<style>
  .portal-ring {
    position: absolute;
    right: -4%;
    top: 50%;
    translate: 0 -50%;
    width: min(400px, 42vw);
    height: auto;
  }
  .topic-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .topic-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--accent-dim);
    border: 1px solid rgba(100,254,218,0.18);
    flex-shrink: 0;
  }
  .topic-icon img {
    filter: invert(85%) sepia(32%) saturate(1374%) hue-rotate(110deg) brightness(103%);
  }
  @media (max-width: 800px) {
    .portal-ring { display: none; }
  }
</style>
