---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  coreKeywords,
  organizationSchema,
  websiteSchema,
  webPageSchema,
  breadcrumbSchema,
} from '../../data/seo.js';

const posts = [
  {
    href: '/blog/why-cognifocus-uses-a-goblin-companion/',
    date: 'May 27, 2026',
    readTime: '5 min',
    title: 'Why CogniFocus Uses a Goblin Companion Instead of a Plain Timer',
    excerpt: 'CogniFocus uses a reactive companion because focus apps work better when they notice drift, respond in the moment, and help you recover quickly.',
    tags: ['CogniFocus', 'Goblin', 'Focus companion'],
  },
  {
    href: '/blog/how-to-stay-focused-at-work/',
    date: 'May 26, 2026',
    readTime: '7 min',
    title: 'How to Stay Focused at Work and Stop Getting Distracted',
    excerpt: 'The average person loses nearly half an hour of deep focus after a single interruption. Learn the structural changes, not willpower tricks, that protect your attention and help you get your best work done.',
    tags: ['Productivity', 'Focus', 'CogniFocus'],
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    organizationSchema,
    websiteSchema,
    webPageSchema({
      id: 'https://cognielevate.co/blog/#webpage',
      url: 'https://cognielevate.co/blog/',
      name: 'Blog | CogniElevate - Productivity, Focus and Intelligent Systems',
      description: 'Insights on productivity, focus, distraction blocking and intelligent systems from the team building CogniFocus and the CogniElevate ecosystem.',
      breadcrumb: true,
    }),
    breadcrumbSchema({
      id: 'https://cognielevate.co/blog/#breadcrumb',
      items: [
        { name: 'Home', url: 'https://cognielevate.co/' },
        { name: 'Blog', url: 'https://cognielevate.co/blog/' },
      ],
    }),
    {
      "@type": "Blog",
      "@id": "https://cognielevate.co/blog/#blog",
      "name": "CogniElevate Blog",
      "url": "https://cognielevate.co/blog/",
      "description": "Insights on productivity, focus, distraction blocking and intelligent systems from the CogniElevate team.",
      "publisher": { "@id": "https://cognielevate.co/#organization" },
      "blogPost": [
        { "@id": "https://cognielevate.co/blog/why-cognifocus-uses-a-goblin-companion/#article" },
        { "@id": "https://cognielevate.co/blog/how-to-stay-focused-at-work/#article" }
      ]
    },
  ]
};
---

<BaseLayout
  title="Blog | CogniElevate - Productivity, Focus and Intelligent Systems"
  description="Insights on productivity, focus, distraction blocking and intelligent systems from the team building CogniFocus and the CogniElevate ecosystem."
  canonical="https://cognielevate.co/blog/"
  keywords={[...coreKeywords, 'CogniElevate blog', 'focus blog', 'productivity blog', 'AI systems blog']}
  activePage="blog"
  schema={schema}
>

  <section class="hero bg-dots" aria-labelledby="blog-title">
    <div class="glow-top" aria-hidden="true"></div>
    <div class="container" style="position:relative;">
      <div style="max-width:700px;" class="fade-up">
        <p class="kicker" style="margin-bottom:1rem;">Blog</p>
        <h1 id="blog-title" class="hero-title">Insights on focus, productivity and intelligent systems</h1>
        <p class="lead" style="margin-top:1.25rem;">
          From the team building CogniFocus and the CogniElevate ecosystem - practical thinking on attention, time, and technology that helps.
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Blog posts">
    <div class="container" style="max-width:820px;">
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {posts.map(({ href, date, readTime, title, excerpt, tags }) => (
          <a href={href} class="card card-p post-card">
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
            <p class="post-meta">{date} | {readTime} read</p>
            <h2 class="post-title">{title}</h2>
            <p class="post-excerpt">{excerpt}</p>
            <span class="read-more">Read article -></span>
          </a>
        ))}

        <div class="card card-p text-center" style="border-style:dashed;border-color:var(--border-m);">
          <p class="kicker" style="margin-bottom:0.5rem;">Coming soon</p>
          <h3 style="font-size:1rem;margin-bottom:0.5rem;">More articles on the way</h3>
          <p style="font-size:0.9rem;">Next: best focus apps for Android, how to build a deep work routine, and the science behind distraction.</p>
          <a href="https://cognifocus.app/" target="_blank" rel="noopener" class="btn btn-ghost btn-sm" style="margin-top:1rem;display:inline-flex;">
            Try CogniFocus in the meantime ->
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
