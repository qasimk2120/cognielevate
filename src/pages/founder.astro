---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  coreKeywords,
  organizationSchema,
  websiteSchema,
  webPageSchema,
  breadcrumbSchema,
} from '../data/seo.js';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    organizationSchema,
    websiteSchema,
    webPageSchema({
      id: 'https://cognielevate.co/founder/#webpage',
      url: 'https://cognielevate.co/founder/',
      name: 'Qasim Khan, Founder of CogniElevate',
      description: 'Qasim Khan is the founder of CogniElevate and creator of CogniFocus, building intelligent products that give people their time back.',
      breadcrumb: true,
    }),
    breadcrumbSchema({
      id: 'https://cognielevate.co/founder/#breadcrumb',
      items: [
        { name: 'Home', url: 'https://cognielevate.co/' },
        { name: 'Founder', url: 'https://cognielevate.co/founder/' },
      ],
    }),
    {
      "@type": "Person",
      "@id": "https://cognielevate.co/founder/#person",
      name: "Qasim Khan",
      jobTitle: "Founder",
      worksFor: {
        "@type": "Organization",
        "@id": "https://cognielevate.co/#organization",
        name: "CogniElevate",
        url: "https://cognielevate.co",
      },
      url: "https://cognielevate.co/founder/",
      image: "https://cognielevate.co/assets/founder-image.jpeg",
      sameAs: [
        "https://x.com/iqasim_explores",
        "https://own.page/iqasimexplores",
      ],
      knowsAbout: [
        "Productivity software",
        "Mobile app development",
        "Focus systems",
        "Intelligent product design",
        "Android development",
      ],
    },
  ]
};

const building = [
  {
    label: 'Shipped',
    title: 'CogniFocus',
    body: 'An Android focus timer and app blocker with a reactive Goblin companion that fights back when you lose focus. Available now on Google Play.',
    href: 'https://cognifocus.app/',
    tag: 'Live on Android',
    accent: true,
  },
  {
    label: 'Next',
    title: 'The CogniElevate Ecosystem',
    body: 'CogniElevate is the parent organization behind CogniFocus. Future products in the ecosystem will reduce wasted time across shopping decisions, healthcare workflows and more.',
    href: '/products/',
    tag: 'Products in development',
    accent: false,
  },
];
---

<BaseLayout
  title="Qasim Khan, Founder of CogniElevate"
  description="Qasim Khan is the founder of CogniElevate and creator of CogniFocus, building intelligent products that give people their time back."
  twitterCreator="@iqasim_explores"
  canonical="https://cognielevate.co/founder/"
  keywords={[...coreKeywords, 'Qasim Khan', 'CogniElevate founder', 'CogniFocus creator', 'technology startup founder', 'intelligent systems builder']}
  activePage="founder"
  schema={schema}
>

  <!-- HERO -->
  <section class="hero bg-dots founder-hero" aria-labelledby="founder-name">
    <div class="glow-top" aria-hidden="true"></div>
    <div class="container">
      <div class="founder-hero-inner">

        <!-- Photo -->
        <div class="founder-photo-wrap fade-up">
          <div class="founder-photo-ring">
            <img
              src="/assets/founder-image.jpeg"
              alt="Qasim Khan, Founder of CogniElevate"
              class="founder-photo"
              width="280"
              height="280"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="founder-photo-glow" aria-hidden="true"></div>
        </div>

        <!-- Identity -->
        <div class="founder-identity fade-up fade-up-1">
          <p class="kicker" style="margin-bottom:0.75rem;">Founder, CogniElevate</p>
          <h1 id="founder-name" class="hero-title" style="margin-bottom:0.75rem;">
            Qasim Khan
          </h1>
          <p class="lead" style="max-width:44ch; margin-bottom:2rem;">
            CogniElevate started with a simple question: where are people losing time, and what system would take that problem away?
          </p>

          <!-- Social links -->
          <div class="founder-links">
            <a
              href="https://own.page/iqasimexplores"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="5"/><path d="M3 21v-2a7 7 0 0 1 14 0v2"/></svg>
              own.page / iqasimexplores
            </a>
            <a
              href="https://x.com/iqasim_explores"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              @iqasim_explores
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHAT I BUILD -->
  <section class="section" id="building" aria-labelledby="building-heading">
    <div class="container">
      <div class="section-head fade-up">
        <p class="kicker">What we build</p>
        <h2 id="building-heading" class="display-sm">Products built around a real friction</h2>
        <p>Every CogniElevate product starts with the same question: where are people losing time? Then we build the system that removes it.</p>
      </div>
      <div class="grid-2 fade-up fade-up-1">
        {building.map(({ label, title, body, href, tag, accent }) => (
          <a href={href} class={`card card-p founder-product-card ${accent ? 'founder-product-card--accent' : ''}`} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
              <span class="kicker" style={accent ? '' : 'color:var(--text-2);'}>{label}</span>
              <span class={accent ? 'outcome-pill' : 'tag'}>{tag}</span>
            </div>
            <h3 style="font-size:1.4rem; margin-bottom:0.75rem;">{title}</h3>
            <p style="font-size:0.93rem;">{body}</p>
            <div style="margin-top:1.5rem; display:flex; align-items:center; gap:0.4rem; font-size:0.875rem; font-weight:600; color:var(--accent);">
              {href.startsWith('http') ? 'Visit →' : 'Learn more →'}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="section" id="approach" style="background:var(--surface);" aria-labelledby="approach-heading">
    <div class="container">
      <div class="section-head fade-up">
        <p class="kicker">How CogniElevate builds</p>
        <h2 id="approach-heading" class="display-sm">Find friction. Build the fix. Ship it.</h2>
      </div>
      <div class="grid-3 fade-up fade-up-1">
        {[
          {
            num: '01',
            title: 'Spot the wasted moment',
            body: 'Start where people keep losing time: focus sessions that collapse, decisions that stall, workflows that drag.',
          },
          {
            num: '02',
            title: 'Build the intelligent layer',
            body: 'Software that reacts and adapts. Active systems that push back, not passive tools that sit there.',
          },
          {
            num: '03',
            title: 'Ship, learn, iterate',
            body: 'Get it live fast. Real users show what actually matters. Then improve until people rely on it.',
          },
        ].map(({ num, title, body }) => (
          <article class="card card-p">
            <span class="process-num">{num}</span>
            <h3 style="font-size:1.05rem; margin:1rem 0 0.6rem;">{title}</h3>
            <p style="font-size:0.9rem;">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS / PROOF -->
  <section class="section" id="proof" aria-labelledby="proof-heading">
    <div class="container">
      <div class="section-head fade-up">
        <p class="kicker">So far</p>
        <h2 id="proof-heading" class="display-sm">Early, but moving fast</h2>
      </div>
      <div class="grid-4 fade-up fade-up-1">
        {[
          { stat: '1',      label: 'Product shipped',         sub: 'CogniFocus on Android' },
          { stat: '5.0★',   label: 'Average rating',          sub: 'Across early reviews'  },
          { stat: '2026',   label: 'Year founded',            sub: 'CogniElevate incorporated' },
          { stat: '∞',      label: 'Products planned',        sub: 'Productivity → Healthcare → Beyond' },
        ].map(({ stat, label, sub }) => (
          <article class="card card-p text-center no-hover">
            <div style="font-size:2rem; font-weight:800; color:var(--accent); letter-spacing:-0.03em; margin-bottom:0.5rem;">{stat}</div>
            <div style="font-size:0.9rem; font-weight:600; color:var(--text); margin-bottom:0.25rem;">{label}</div>
            <div style="font-size:0.78rem; color:var(--muted);">{sub}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PRESS -->
  <section class="section-sm" aria-label="Press coverage">
    <div class="container" style="max-width:760px;">
      <p class="kicker" style="text-align:center; margin-bottom:1.5rem;">As seen in</p>
      <a
        href="https://startupfortune.com/qasim-built-cognifocus-because-most-focus-apps-keep-counting-while-your-brain-is-already-on-tiktok/"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-p"
        style="display:block; text-decoration:none; border-color:rgba(34,211,238,0.18); background:linear-gradient(135deg,var(--surface) 0%,rgba(34,211,238,0.03) 100%);"
      >
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:1rem;">
          <div style="width:36px;height:36px;border-radius:8px;background:var(--surface-3);border:1px solid var(--border-m);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8z"/></svg>
          </div>
          <span style="font-size:0.8rem; font-weight:700; color:var(--text-2);">Startup Fortune</span>
        </div>
        <p style="font-size:1.05rem; font-weight:600; color:var(--text); line-height:1.45; margin-bottom:0.75rem;">
          "CogniFocus Catches You Mid-Scroll During a Focus Session — That Is the Entire Point"
        </p>
        <span style="font-size:0.85rem; font-weight:600; color:var(--accent);">Read the story →</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm">
    <div class="container">
      <div class="cta-panel card card-p-lg" style="border-radius:var(--radius-lg);">
        <p class="kicker" style="margin-bottom:0.75rem;">Get in touch</p>
        <h2 class="display-sm" style="margin-bottom:0.75rem;">
          Partnerships, ideas, or a friction problem worth solving
        </h2>
        <p style="max-width:52ch; margin:0 auto 2rem;">
          If you're building something interesting or want to work with CogniElevate, reach out.
        </p>
        <div class="cta-actions">
          <a href="/contact/" class="btn btn-primary btn-lg">Contact CogniElevate</a>
          <a href="/products/" class="btn btn-outline btn-lg">See our products</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* Founder hero layout */
.founder-hero { padding-bottom: clamp(4rem, 8vw, 7rem); }
.founder-hero-inner {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: clamp(2.5rem, 6vw, 5rem);
  align-items: center;
}
@media (max-width: 700px) {
  .founder-hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .founder-links { justify-content: center; }
}

/* Photo */
.founder-photo-wrap {
  position: relative;
  flex-shrink: 0;
}
.founder-photo-ring {
  position: relative;
  width: 220px;
  height: 220px;
  border-radius: 50%;
  padding: 3px;
  background: linear-gradient(135deg, rgba(34,211,238,0.6) 0%, rgba(129,140,248,0.4) 50%, rgba(34,211,238,0.1) 100%);
  box-shadow: 0 0 40px rgba(34,211,238,0.2), 0 0 80px rgba(34,211,238,0.08);
}
.founder-photo {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  object-position: top center;
  display: block;
  background: var(--surface-2);
}
.founder-photo-glow {
  position: absolute;
  inset: -20px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(34,211,238,0.12) 0%, transparent 70%);
  pointer-events: none;
  z-index: -1;
}
@media (max-width: 700px) {
  .founder-photo-ring { width: 160px; height: 160px; margin: 0 auto; }
}

/* Social links row */
.founder-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
}

/* Product cards */
.founder-product-card {
  text-decoration: none;
  color: inherit;
  display: block;
}
.founder-product-card--accent {
  border-color: rgba(34,211,238,0.25);
  background: linear-gradient(135deg, var(--surface) 0%, rgba(34,211,238,0.04) 100%);
}
.founder-product-card--accent:hover {
  border-color: rgba(34,211,238,0.5);
  box-shadow: 0 0 32px rgba(34,211,238,0.1), var(--shadow-lg);
}

/* Process number */
.process-num {
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  color: var(--accent);
  font-family: var(--mono);
}
</style>

