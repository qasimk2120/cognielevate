---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | CogniElevate"
  description="Read the CogniElevate Privacy Policy to understand how information may be collected, used, and protected across our website and products."
  canonical="https://cognielevate.co/privacy/"
  robots="noindex, follow"
>

  <section style="padding: clamp(4rem,8vw,6rem) 0;">
    <div class="container" style="max-width:860px;">
      <article class="card card-p-lg">
        <header style="border-bottom:1px solid var(--border);padding-bottom:1.25rem;margin-bottom:0;">
          <p class="kicker" style="margin-bottom:0.6rem;">Legal</p>
          <h1 style="font-size:clamp(1.75rem,3vw,2.5rem);letter-spacing:-0.02em;">Privacy Policy</h1>
          <p style="font-size:0.85rem;color:var(--muted);margin-top:0.4rem;">Last updated: 2026</p>
        </header>

        <div class="policy-section">
          <h2>Overview</h2>
          <p>This Privacy Policy explains how CogniElevate collects, uses, and protects information when you visit our website or interact with our products.</p>
        </div>

        <div class="policy-section">
          <h2>Information We Collect</h2>
          <p>We may collect:</p>
          <ul>
            <li>Basic contact information such as email</li>
            <li>Device and browser information</li>
            <li>Usage and interaction data</li>
          </ul>
        </div>

        <div class="policy-section">
          <h2>How We Use Information</h2>
          <ul>
            <li>Improve product performance</li>
            <li>Respond to support requests</li>
            <li>Analyze usage trends</li>
          </ul>
        </div>

        <div class="policy-section">
          <h2>Data Sharing</h2>
          <p>We do not sell personal information. Data may be shared with trusted services that help operate the platform.</p>
        </div>

        <div class="policy-section">
          <h2>Data Security</h2>
          <p>We apply reasonable safeguards, but no system is 100% secure.</p>
        </div>

        <div class="policy-section">
          <h2>Your Rights</h2>
          <p>You may request access, updates, or deletion depending on your jurisdiction.</p>
        </div>

        <div class="policy-section">
          <h2>Contact</h2>
          <p>Email: <a href="mailto:cognielevate@gmail.com" style="color:var(--accent);">cognielevate@gmail.com</a></p>
        </div>
      </article>
    </div>
  </section>

</BaseLayout>
